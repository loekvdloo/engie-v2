    {
      "name": "4) Read Endpoints",
      "item": [
        {
          "name": "Get all messages",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/messages", "host": ["{{base_url}}"], "path": ["api", "messages"] }
          }
        },
        {
          "name": "Get message by id (messageId_last)",
          "request": {
