{
  "info": {
    "_postman_id": "engie-mca-api-2026-03",
    "name": "ENGIE MCA API (Up-to-date)",
    "description": "Actuele collectie voor de 29-stappen pipeline (1A-6B).\n\nBase URL variable: {{base_url}}\nAanbevolen waarde: http://localhost:5000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1) Pipeline - Happy Flow",
      "item": [
        {
          "name": "Process valid AllocationSeries (Delivered/Ack)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code 200', function () { pm.response.to.have.status(200); });",
                  "var r = pm.response.json();",
                  "pm.test('Delivered + Ack + no errors', function () {",
                  "  pm.expect(r.status).to.eql('Delivered');",
                  "  pm.expect(r.responseType).to.eql('Ack');",
                  "  pm.expect(r.errorCount).to.eql(0);",
                  "});",
                  "pm.collectionVariables.set('messageId_last', r.messageId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Correlation-ID", "value": "corr-postman-valid-001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messageId\": \"postman-valid-001\",\n  \"xmlContent\": \"<AllocationSeries><DocumentID>DOC-POSTMAN-001</DocumentID><EAN>871234567890100000</EAN><Quantity>100</Quantity><StartDateTime>2026-03-28T08:00:00Z</StartDateTime><EndDateTime>2026-03-28T09:00:00Z</EndDateTime></AllocationSeries>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/messages",
              "host": ["{{base_url}}"],
              "path": ["api", "messages"]
            }
          }
        }
      ]
    },
    {
      "name": "2) Pipeline - Step 1 Failures (001)",
      "item": [
        {
          "name": "Invalid XML (1C -> 001)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "pm.test('Failed with error 001', function () {",
                  "  pm.expect(r.status).to.eql('Failed');",
                  "  pm.expect(r.errorCodes).to.include('001');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messageId\": \"postman-invalidxml-001\",\n  \"xmlContent\": \"geen xml\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/messages",
              "host": ["{{base_url}}"],
              "path": ["api", "messages"]
            }
          }
        },
        {
          "name": "Unknown root type (1E -> 001)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "pm.test('Failed with error 001', function () {",
                  "  pm.expect(r.status).to.eql('Failed');",
                  "  pm.expect(r.errorCodes).to.include('001');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messageId\": \"postman-unknowntype-001\",\n  \"xmlContent\": \"<UnknownType><DocumentID>DOC-U-001</DocumentID><EAN>871234567890100000</EAN><Quantity>10</Quantity><StartDateTime>2026-03-28T08:00:00Z</StartDateTime><EndDateTime>2026-03-28T09:00:00Z</EndDateTime></UnknownType>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/messages",
              "host": ["{{base_url}}"],
              "path": ["api", "messages"]
            }
          }
        }
      ]
    },
